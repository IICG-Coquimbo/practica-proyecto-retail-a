   "outputs": [],
   "source": [
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql import functions as F\n",
    "\n",
    "# 1. Cargar datos\n",
    "spark = SparkSession.builder \\\n",
    "    .appName(\"Analisis_Categorias\") \\\n",
    "    .config(\"spark.mongodb.read.connection.uri\", \"mongodb://database:27017/proyecto_bigdata.datos_libros\") \\\n",
    "    .config(\"spark.jars.packages\", \"org.mongodb.spark:mongo-spark-connector_2.12:10.1.1\") \\\n",
    "    .getOrCreate()\n",
    "\n",
    "df = spark.read.format(\"mongodb\").load()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "58be22c5",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.printSchema()\n",
    "df.show(5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8dde87e1",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import col\n",
    "\n",
    "# Solo queremos registros que tengan un item real y un valor mayor a 0\n",
    "df_filtrado = df.filter((col(\"item\").isNotNull()) & (col(\"valor\") > 0))\n",
    "\n",
    "print(\"PASO 2: Limpieza completada.\")\n",
    "print(\"Registros originales:\", df.count())\n",
    "print(\"Registros validos:\", df_filtrado.count())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8948aefe",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.select(\"item\", \"valor\").show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "31a2fa34",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.filter(df[\"valor\"] > 100).show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3280c3cc",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.groupBy(\"grupo\").count().show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a3e8d93a",
   "metadata": {},
   "outputs": [],
   "source": [
    "reporte_categorias = df.groupBy(\"categoria\").agg(\n",
    "    F.count(\"item\").alias(\"cantidad_libros\"),\n",
    "    F.avg(\"valor\").alias(\"precio_promedio\"),\n",
    "    F.min(\"valor\").alias(\"precio_minimo\"),\n",
    "    F.max(\"valor\").alias(\"precio_maximo\")\n",
    ").orderBy(F.desc(\"precio_promedio\"))\n",
    "\n",
    "print(\"ANALISIS DE MERCADO POR CATEGORIA:\")\n",
    "reporte_categorias.show()"
   ]
  }
 ],
