    "        # Limpieza robusta de precios chilenos\n",
    "        raw = d[\"valor\"].replace(\"$\", \"\").replace(\".\", \"\").replace(\",\", \".\").strip()\n",
    "        numeros = re.findall(r'\\d+[.,]?\\d*', raw)\n",
