    "\n",
    "# 3. Procesamiento de datos y Reporte Final\n",
    "if datos_finales:\n",
    "    # Calcular precio promedio de lo capturado\n",
    "    precios = [p[\"precio\"] for p in datos_finales]\n",
    "    precio_promedio_categoria = int(round(sum(precios) / len(precios)))\n",
    "\n",
    "    # Inyectar el promedio en cada documento (denormalización útil para analítica)\n",
    "    for doc in datos_finales:\n",
    "        doc[\"precio_promedio\"] = precio_promedio_categoria\n",
    "\n",
    "    print(\"\\n\" + \"=\"*100)\n",
    "    print(f\"RESUMEN DEL SCRAPING\")\n",
    "    print(\"=\"*100)\n",
    "    print(f\"Total productos capturados: {len(datos_finales)}\")\n",
    "    print(f\"Precio promedio calculado:  ${precio_promedio_categoria:,}\")\n",
    "    print(\"-\" * 100)\n",
    "\n",
    "    # Mostrar lista detallada\n",
    "    for i, producto in enumerate(datos_finales, 1):\n",
    "        print(f\"{i:4d}. ${producto['precio']:>8,} | {producto['marca']:>15} | {producto['nombre_producto']}\")\n",
    "    \n",
    "    print(f\"\\nPROCESO COMPLETADO EXITOSAMENTE\")\n",
    "else:\n",
    "    print(\"\\nNo se pudieron obtener datos. Verifica la conexión o los selectores CSS.\")"
