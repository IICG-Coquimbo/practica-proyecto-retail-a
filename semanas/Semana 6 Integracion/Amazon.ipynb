    "import os\n",
    "import time\n",
    "import re\n",
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.options import Options\n",
    "from selenium.webdriver.common.by import By\n",
    "\n",
    "# 1. Limpieza de procesos previos\n",
    "os.system(\"pkill -9 chrome\")\n",
    "os.system(\"pkill -9 chromedriver\")\n",
    "print(\"Limpieza completada\")\n",
    "\n",
    "# 2. Configuración del navegador\n",
    "options = Options()\n",
    "options.add_argument(\"--no-sandbox\")\n",
    "options.add_argument(\"--disable-dev-shm-usage\")\n",
    "options.add_argument(\"--window-size=1366,768\")\n",
    "options.add_argument(\"--disable-blink-features=AutomationControlled\")\n",
    "\n",
    "driver = None\n",
    "datos_finales = []\n",
    "base_url = \"https://www.santaisabel.cl/lacteos-huevos-y-congelados\"\n",
    "\n",
    "print(\"Iniciando scraping de Lacteos (25 paginas)...\")\n",
    "\n",
    "try:\n",
    "    driver = webdriver.Chrome(options=options)\n",
    "    \n",
    "    for pagina in range(1, 26):\n",
    "        url = f\"{base_url}?page={pagina}\" if pagina > 1 else base_url\n",
    "        print(f\"\\n{'='*20} PAGINA {pagina}/25 {'='*20}\")\n",
    "        print(f\"URL: {url}\")\n",
    "        \n",
    "        driver.get(url)\n",
    "        time.sleep(6) # Espera para carga de JS\n",
    "        \n",
    "        # Localizar contenedores de productos\n",
    "        bloques = driver.find_elements(By.CSS_SELECTOR, \n",
    "            \"div[class*='product'], div[class*='Product'], div[class*='item'], div[class*='tile'], article\"\n",
    "        )\n",
    "        \n",
    "        print(f\"Bloques encontrados en esta pagina: {len(bloques)}\")\n",
    "        \n",
    "        for i, bloque in enumerate(bloques):\n",
    "            try:\n",
    "                # EXTRAER NOMBRE\n",
    "                nombre = \"Sin nombre\"\n",
    "                for selector in [\"h3\", \"h2\", \".product-name\", \".title\", \"[class*='name']\"]:\n",
    "                    try:\n",
    "                        elem = bloque.find_element(By.CSS_SELECTOR, selector)\n",
    "                        nombre = elem.text.strip()\n",
    "                        if len(nombre) > 5:\n",
    "                            break\n",
    "                    except:\n",
    "                        continue\n",
    "                \n",
    "                # EXTRAER MARCA (Regex mejorado para tildes)\n",
    "                marca = \"Sin marca\"\n",
    "                if nombre != \"Sin nombre\":\n",
    "                    match = re.match(r'^([A-ZÀ-Ú][a-zà-ú]+(?:\\s[A-ZÀ-Ú][a-zà-ú]+)?)', nombre)\n",
    "                    if match:\n",
    "                        marca = match.group(1)\n",
    "                \n",
    "                # EXTRAER PRECIO\n",
    "                precio_elems = bloque.find_elements(By.XPATH, \".//*[contains(text(), '$')]\")\n",
    "                precio = 0\n",
    "                \n",
    "                for p_elem in precio_elems:\n",
    "                    p_texto = p_elem.text.strip()\n",
    "                    # Ignorar precios por unidad de medida (PUM)\n",
    "                    if any(unit in p_texto.lower() for unit in ['x un', 'x kg', 'x lt', 'x ml']):\n",
    "                        continue\n",
    "                    \n",
    "                    p_limpio = re.sub(r'[^\\d]', '', p_texto)\n",
    "                    if len(p_limpio) >= 3:\n",
    "                        precio = int(p_limpio)\n",
    "                        break\n",
    "                \n",
    "                # GUARDAR SI ES VALIDO\n",
    "                if nombre != \"Sin nombre\" and precio > 0:\n",
    "                    datos_finales.append({\n",
    "                        \"nombre_producto\": nombre,\n",
    "                        \"precio\": precio,\n",
    "                        \"supermercado\": \"Santa Isabel\",\n",
    "                        \"categoria\": \"Lacteos Huevos Congelados\",\n",
    "                        \"marca\": marca,\n",
    "                        \"pagina\": pagina,\n",
    "                        \"fecha_scraping\": time.strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "                    })\n",
    "                    print(f\"{len(datos_finales):4d} | ${precio:>8,} | {marca:>12} | {nombre[:50]}\")\n",
    "\n",
    "            except Exception as e:\n",
    "                continue # Si falla un bloque, saltar al siguiente\n",
    "\n",
    "        print(f\"PAGINA {pagina} FINALIZADA.\")\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"Error crítico en el proceso: {e}\")\n",
    "\n",
    "finally:\n",
    "    if driver:\n",
