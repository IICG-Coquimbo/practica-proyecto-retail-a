    "# --- SCRAPER CANASTA BÁSICA ACUENTA.CL - VERSIÓN PAGINACIÓN AVANZADA ---\n",
    "import os\n",
    "import time\n",
    "import random\n",
    "import re\n",
    "from pymongo import MongoClient\n",
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.options import Options\n",
    "from selenium.webdriver.common.by import By\n",
    "from selenium.webdriver.support.ui import WebDriverWait\n",
    "from selenium.webdriver.support import expected_conditions as EC\n",
    "from selenium.common.exceptions import TimeoutException, NoSuchElementException, StaleElementReferenceException\n",
    "\n",
    "os.system(\"pkill -9 chrome\")\n",
    "os.system(\"pkill -9 chromedriver\")\n",
    "print(\"🧹 Scraper Canasta Básica iniciado\")\n",
    "\n",
    "# VARIABLES\n",
    "URL_CANASTA = \"https://www.acuenta.cl/ca/despensa/05\"\n",
    "NOMBRE_GRUPO = \"Canasta Básica Acuenta\"\n",
    "datos_finales = []\n",
    "pagina_actual = 1\n",
    "\n",
    "# Configuración anti-detección\n",
    "options = Options()\n",
    "options.binary_location = \"/usr/bin/google-chrome\"\n",
    "options.add_argument(\"--no-sandbox\")\n",
    "options.add_argument(\"--disable-dev-shm-usage\")\n",
    "options.add_argument(\"--window-size=1920,1080\")\n",
    "options.add_argument(\"--disable-blink-features=AutomationControlled\")\n",
    "options.add_experimental_option(\"excludeSwitches\", [\"enable-automation\"])\n",
    "options.add_experimental_option('useAutomationExtension', False)\n",
    "options.add_argument(\"user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36\")\n",
    "\n",
    "driver = None\n",
    "try:\n",
    "    driver = webdriver.Chrome(options=options)\n",
    "    driver.execute_cdp_cmd(\"Page.addScriptToEvaluateOnNewDocument\", {\n",
    "        \"source\": \"Object.defineProperty(navigator, 'webdriver', {get: () => })\"\n",
    "    })\n",
    "    print(\"🚀 Navegador listo\")\n",
    "\n",
    "    # 🔄 SISTEMA DE PAGINACIÓN AVANZADO\n",
    "    while True:\n",
    "        print(f\"\\n📄 === PÁGINA {pagina_actual} ===\")\n",
    "        print(f\"🛍️ Cargando: {URL_CANASTA}\")\n",
    "        \n",
    "        driver.get(URL_CANASTA)\n",
    "        time.sleep(random.uniform(8, 12))\n",
    "\n",
    "        # Cookies\n",
    "        try:\n",
    "            cookie_btn = WebDriverWait(driver, 5).until(\n",
    "                EC.element_to_be_clickable((By.XPATH, \"//button[contains(text(), 'Aceptar') or contains(text(), 'Acepto') or contains(@class, 'cookie')]\"))\n",
    "            )\n",
    "            cookie_btn.click()\n",
    "            print(\"🍪 Cookies aceptadas\")\n",
    "            time.sleep(2)\n",
    "        except:\n",
    "            print(\"ℹ️ Sin cookies\")\n",
    "\n",
    "        # 📜 Scroll agresivo por página\n",
    "        print(\"📜 Scroll para cargar productos...\")\n",
    "        last_height = driver.execute_script(\"return document.body.scrollHeight\")\n",
    "        scroll_count = 0\n",
    "        \n",
    "        while scroll_count < 15:\n",
    "            driver.execute_script(\"window.scrollTo(0, document.body.scrollHeight);\")\n",
    "            time.sleep(random.uniform(1.5, 3))\n",
    "            new_height = driver.execute_script(\"return document.body.scrollHeight\")\n",
    "            \n",
    "            if new_height == last_height:\n",
    "                time.sleep(2)\n",
    "                if driver.execute_script(\"return document.body.scrollHeight\") == new_height:\n",
    "                    break\n",
    "            last_height = new_height\n",
    "            scroll_count += 1\n",
    "        \n",
    "        time.sleep(3)\n",
    "\n",
    "        # 🔍 SELECTORES OPTIMIZADOS\n",
    "        print(\"🔍 Buscando productos...\")\n",
    "        \n",
    "        selectores_canasta = [\n",
    "            \"div[class*='product']\", \"div[class*='ProductCard']\",\n",
    "            \"div[class*='product-card']\", \"div[class*='card']\",\n",
    "            \".product-item\", \"[data-testid*='product']\",\n",
    "            \"article[class*='product']\", \".grid-item\", \".product-grid-item\"\n",
    "        ]\n",
    "        \n",
    "        bloques = []\n",
    "        for selector in selectores_canasta:\n",
    "            try:\n",
    "                bloques = driver.find_elements(By.CSS_SELECTOR, selector)\n",
    "                if len(bloques) > 2:\n",
    "                    print(f\"✅ {len(bloques)} productos con '{selector}'\")\n",
    "                    break\n",
    "            except:\n",
    "                continue\n",
    "\n",
    "        # Fallback por precios\n",
    "        if not bloques or len(bloques) < 3:\n",
    "            print(\"🔍 Fallback: buscando por PRECIOS...\")\n",
    "            bloques = driver.find_elements(By.XPATH, \"//*[contains(text(), '$')]/ancestor::div[1|2|3]\")\n",
    "            bloques = list(set(bloques))[:50]\n",
    "            print(f\"✅ {len(bloques)} productos por precio\")\n",
    "\n",
    "        if not bloques:\n",
    "            print(\"⚠️ No se encontraron productos en esta página\")\n",
    "            break\n",
    "\n",
    "        # 📦 EXTRACCIÓN MEJORADA CON TODAS LAS ETIQUETAS\n",
    "        print(f\"📦 Procesando {len(bloques)} productos...\")\n",
    "        productos_pagina = 0\n",
    "        \n",
    "        for i, bloque in enumerate(bloques[:50]):\n",
    "            try:\n",
    "                # 🏷️ NOMBRE\n",
    "                nombre = None\n",
    "                selectores_nombre = [\n",
    "                    \"[class*='name']\", \"[class*='title']\", \"h3\", \"h2\", \"h4\",\n",
    "                    \".product-name\", \".titulo\", \"[data-testid*='name']\", \".product-title\"\n",
    "                ]\n",
    "                \n",
    "                for sel in selectores_nombre:\n",
    "                    try:\n",
    "                        elem = bloque.find_element(By.CSS_SELECTOR, sel)\n",
    "                        nombre_cand = elem.text.strip()\n",
    "                        if len(nombre_cand) > 3 and len(nombre_cand) < 120:\n",
    "                            nombre = nombre_cand\n",
    "                            break\n",
    "                    except:\n",
    "                        continue\n",
    "                \n",
    "                # Fallback nombre\n",
    "                if not nombre:\n",
    "                    texto = bloque.text.strip()\n",
    "                    lineas = [l.strip() for l in texto.split('\\n') if l.strip()]\n",
    "                    for linea in lineas:\n",
    "                        if '$' not in linea and len(linea) > 3 and len(linea) < 100:\n",
    "                            nombre = linea\n",
    "                            break\n",
    "\n",
    "                # 💰 PRECIO\n",
    "                precio = None\n",
    "                selectores_precio = [\n",
    "                    \"[class*='price']\", \"[class*='precio']\", \".price\",\n",
    "                    \"span[class*='price']\", \"[data-testid*='price']\",\n",
    "                    \".precio-final\", \".current-price\"\n",
    "                ]\n",
    "                \n",
    "                for sel in selectores_precio:\n",
    "                    try:\n",
    "                        elem = bloque.find_element(By.CSS_SELECTOR, sel)\n",
    "                        precio_cand = elem.text.strip()\n",
    "                        if '$' in precio_cand:\n",
    "                            precio = precio_cand\n",
    "                            break\n",
    "                    except:\n",
    "                        continue\n",
    "                \n",
    "                # Fallback precio\n",
    "                if not precio:\n",
    "                    match = re.search(r'\\$[\\d,\\.\\s]+', bloque.text)\n",
    "                    precio = match.group() if match else None\n",
    "\n",
    "                # 🏪 MARCA\n",
    "                marca = None\n",
    "                selectores_marca = [\n",
    "                    \"[class*='brand']\", \"[class*='marca']\", \".brand-name\",\n",
    "                    \"[data-testid*='brand']\"\n",
    "                ]\n",
    "                \n",
    "                for sel in selectores_marca:\n",
    "                    try:\n",
    "                        elem = bloque.find_element(By.CSS_SELECTOR, sel)\n",
    "                        marca_cand = elem.text.strip()\n",
    "                        if len(marca_cand) > 1 and len(marca_cand) < 30:\n",
    "                            marca = marca_cand.upper()\n",
    "                            break\n",
    "                    except:\n",
    "                        continue\n",
    "\n",
    "                # ✅ GUARDAR CON TODAS LAS ETIQUETAS\n",
    "                if nombre and precio:\n",
    "                    datos_finales.append({\n",
    "                        \"nombre\": nombre[:100],\n",
    "                        \"precio\": precio,\n",
    "                        \"precio_limpio\": 0.0,\n",
    "                        \"marca\": marca or \"SIN MARCA\",\n",
    "                        \"supermercado\": \"ACUENTA\",\n",
    "                        \"fecha_scraping\": time.strftime(\"%Y-%m-%d %H:%M:%S\"),\n",
    "                        \"grupo\": NOMBRE_GRUPO,\n",
    "                        \"url\": URL_CANASTA,\n",
    "                        \"pagina\": pagina_actual,\n",
    "                        \"posicion\": len(datos_finales) + 1,\n",
    "                        \"categoria\": \"Canasta Básica\"\n",
    "                    })\n",
    "                    productos_pagina += 1\n",
    "                    print(f\"✅ [{productos_pagina:2d}] {nombre[:40]:<40} ${precio} | {marca or ''}\")\n",
    "\n",
    "            except Exception as e:\n",
    "                continue\n",
    "\n",
    "        print(f\"🎉 Página {pagina_actual}: {productos_pagina} productos\")\n",
    "\n",
    "        # 🔎 DETECTAR SIGUIENTE PÁGINA\n",
    "        print(\"🔎 Buscando siguiente página...\")\n",
    "        selectores_paginacion = [\n",
    "            \"a[aria-label*='siguiente']\", \"a[aria-label*='next']\",\n",
    "            \".pagination-next\", \".next-page\", \"a[class*='next']\",\n",
    "            \"button[class*='next']\", \".page-next\",\n",
    "            \"//a[contains(text(), 'Siguiente') or contains(text(), '→')]\",\n",
    "            \"//button[contains(text(), 'Siguiente') or contains(text(), '→')]\"\n",
    "        ]\n",
    "        \n",
    "        siguiente_encontrado = False\n",
    "        for selector in selectores_paginacion:\n",
    "            try:\n",
    "                if \"//\" in selector:\n",
    "                    elementos = driver.find_elements(By.XPATH, selector)\n",
    "                else:\n",
    "                    elementos = driver.find_elements(By.CSS_SELECTOR, selector)\n",
    "                \n",
    "                for elem in elementos:\n",
    "                    if elem.is_enabled() and elem.is_displayed():\n",
    "                        driver.execute_script(\"arguments[0].scrollIntoView(true);\", elem)\n",
    "                        time.sleep(1)\n",
    "                        elem.click()\n",
    "                        print(f\"✅ → PÁGINA {pagina_actual + 1} (selector: {selector[:30]})\")\n",
    "                        pagina_actual += 1\n",
    "                        siguiente_encontrado = True\n",
    "                        time.sleep(random.uniform(3, 5))\n",
    "                        break\n",
    "                if siguiente_encontrado:\n",
    "                    break\n",
    "            except (StaleElementReferenceException, TimeoutException):\n",
    "                continue\n",
    "\n",
    "        # 🛑 DETENER SI NO HAY MÁS PÁGINAS\n",
    "        if not siguiente_encontrado or productos_pagina < 3:\n",
    "            print(\"🛑 No hay más páginas\")\n",
    "            break\n",
    "\n",
    "        # ⏸️ PAUSA ENTRE PÁGINAS\n",
    "        time.sleep(random.uniform(5, 8))\n",
    "\n",
    "    print(f\"\\n🎉 TOTAL: {len(datos_finales)} productos de {pagina_actual} páginas\")\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"❌ Error: {e}\")\n",
    "finally:\n",
    "    if driver:\n",
    "        driver.quit()\n",
    "\n",
    "# 💰 LIMPIEZA PROFESIONAL\n",
    "if datos_finales:\n",
    "    print(\"\\n💰 Limpiando precios...\")\n",
    "    precios_limpios = []\n",
    "    \n",
    "    for d in datos_finales:\n",
    "        # Patrón pesos chilenos\n",
    "        patron = r'\\$([0-9]{1,3}(?:\\.[0-9]{3})*(?:,\\d+)?)'\n",
    "        match = re.search(patron, d[\"precio\"])\n",
    "        \n",
    "        if match:\n",
    "            precio_str = match.group(1).replace('.', '').replace(',', '.')\n",
    "            try:\n",
    "                precio = float(precio_str)\n",
    "                if precio > 0:\n",
    "                    d[\"precio_limpio\"] = precio\n",
    "                    precios_limpios.append(precio)\n",
    "            except:\n",
    "                continue\n",
    "\n",
    "    # 📊 TABLA COMPLETA CON TODAS LAS ETIQUETAS\n",
    "    print(\"\\n\" + \"═\"*120)\n",
    "    print(\"🛒  CANASTA BÁSICA ACUENTA.CL - COMPLETA\")\n",
    "    print(f\"🔗 {URL_CANASTA} | 📄 {pagina_actual} páginas\")\n",
    "    print(\"═\"*120)\n",
    "    print(f\"{'PRODUCTO':<45} {'MARCA':<12} {'PRECIO':>10} {'PÁG':>4}\")\n",
    "    print(\"─\"*120)\n",
    "    \n",
    "    for d in datos_finales:\n",
    "        if d[\"precio_limpio\"] > 0:\n",
    "            print(f\"{d['nombre'][:45]:<45} {d['marca'][:12]:<12} ${d['precio_limpio']:>9,.0f} {d['pagina']:>4}\")\n",
    "    \n",
    "    # 📈 ESTADÍSTICAS\n",
    "    if precios_limpios:\n",
    "        total = sum(precios_limpios)\n",
    "        promedio = total / len(precios_limpios)\n",
    "        \n",
    "        print(\"─\"*120)\n",
    "        print(f\"{'TOTAL PRODUCTOS:':<45} {len(precios_limpios):>12} {'PROMEDIO:':<12} ${promedio:>9,.0f}\")\n",
    "        print(f\"{'COSTO TOTAL CANASTA:':<45} ${total:>9,.0f} {'MÁXIMO:':<12} ${max(precios_limpios):>9,.0f}\")\n",
    "        print(f\"{'SUPERMERCADO:':<45} {datos_finales[0]['supermercado']:>12} {'FECHA:':<12} {datos_finales[0]['fecha_scraping']}\")\n",
    "        print(\"═\"*120)\n",
    "\n",
    "        # 💾 EXPORTACIONES\n",
    "        import json\n",
    "        \n",
    "        # JSON completo\n",
    "        with open(\"canasta_basica_acuenta_COMPLETA.json\", \"w\", encoding=\"utf-8\") as f:\n",
    "            json.dump(datos_finales, f, ensure_ascii=False, indent=2)\n",
    "        print(\"💾 ✅ canasta_basica_acuenta_COMPLETA.json\")\n",
    "        \n",
    "        # Resumen TXT\n",
    "        with open(\"resumen_canasta_basica_COMPLETO.txt\", \"w\", encoding=\"utf-8\") as f:\n",
    "            f.write(f\"CANASTA BÁSICA ACUENTA.CL\\n\")\n",
    "            f.write(f\"URL: {URL_CANASTA}\\n\")\n",
    "            f.write(f\"Páginas: {pagina_actual} | Fecha: {time.strftime('%Y-%m-%d %H:%M:%S')}\\n\\n\")\n",
    "            f.write(f\"TOTAL: {len(precios_limpios)} productos | COSTO: ${total:,.0f}\\n\")\n",
    "            f.write(f\"PROMEDIO: ${promedio:,.0f} | Supermercado: ACUENTA\\n\\n\")\n",
    "            f.write(\"DETALLE:\\n\" + \"─\"*80 + \"\\n\")\n",
    "            for d in datos_finales:\n",
    "                if d[\"precio_limpio\"] > 0:\n",
    "                    f.write(f\"${d['precio_limpio']:>9,.0f} | {d['marca']:<12} | {d['nombre']}\\n\")\n",
    "        \n",
    "        print(\"💾 ✅ resumen_canasta_basica_COMPLETO.txt\")\n",
    "        \n",
    "        # MongoDB\n",
    "        try:\n",
    "            client = MongoClient(\"mongodb\", 27017, serverSelectionTimeoutMS=5000)\n",
    "            db = client[\"Canasta_db\"]\n",
    "            db[\"Canasta_Basica_Acuenta_Completa\"].insert_many(datos_finales)\n",
    "            print(\"💾 ✅ MongoDB COMPLETO\")\n",
    "        except:\n",
    "            print(\"⚠️ Sin MongoDB\")\n",
    "\n",
    "else:\n",
    "    print(\"❌ No se encontraron productos\")"
   ]
