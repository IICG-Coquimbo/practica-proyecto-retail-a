   "source": [
    "# --- SCRAPER 15 PÁGINAS - ULTRA ESTABLE CON RECONEXIÓN ---\n",
    "import os\n",
    "import time\n",
    "import random\n",
    "import re\n",
    "import json\n",
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.options import Options\n",
    "from selenium.webdriver.common.by import By\n",
    "from selenium.webdriver.support.ui import WebDriverWait\n",
    "from selenium.webdriver.support import expected_conditions as EC\n",
    "from selenium.common.exceptions import TimeoutException, NoSuchElementException, WebDriverException\n",
    "\n",
    "os.system(\"pkill -9 chrome\")\n",
    "os.system(\"pkill -9 chromedriver\")\n",
    "print(\"🧹 SCRAPER ULTRA-ESTABLE - 15 PÁGINAS CON RECONEXIÓN\")\n",
    "\n",
    "URL_BASE = \"https://www.acuenta.cl/ca/despensa/05\"\n",
    "MAX_PAGINAS = 15\n",
    "datos_finales = []\n",
    "productos_vistos = set()\n",
    "\n",
    "def crear_driver():\n",
    "    \"\"\"🔧 Crea driver estable\"\"\"\n",
    "    options = Options()\n",
    "    options.binary_location = \"/usr/bin/google-chrome\"\n",
    "    options.add_argument(\"--no-sandbox\")\n",
    "    options.add_argument(\"--disable-dev-shm-usage\")\n",
    "    options.add_argument(\"--disable-gpu\")\n",
    "    options.add_argument(\"--window-size=1920,1080\")\n",
    "    options.add_argument(\"--disable-blink-features=AutomationControlled\")\n",
    "    options.add_experimental_option(\"excludeSwitches\", [\"enable-automation\"])\n",
    "    options.add_experimental_option('useAutomationExtension', False)\n",
    "    options.add_argument(\"user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\")\n",
    "    \n",
    "    driver = webdriver.Chrome(options=options)\n",
    "    driver.execute_cdp_cmd(\"Page.addScriptToEvaluateOnNewDocument\", {\n",
    "        \"source\": \"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\"\n",
    "    })\n",
    "    return driver\n",
    "\n",
    "# 🌈 CATEGORÍAS\n",
    "CATEGORIAS = {\n",
    "    'arroz': 'Arroz', 'fideo': 'Pastas', 'pasta': 'Pastas', 'espagueti': 'Pastas',\n",
    "    'aceite': 'Aceites', 'mayonesa': 'Salsas', 'ketchup': 'Salsas', 'salsa': 'Salsas',\n",
    "    'atún': 'Conservas', 'jurel': 'Conservas', 'caballa': 'Conservas', 'azúcar': 'Azúcares', \n",
    "    'harina': 'Harinas', 'porotos': 'Legumbres', 'lentejas': 'Legumbres'\n",
    "}\n",
    "\n",
    "def extraer_producto(bloque):\n",
    "    \"\"\"🎯 Extracción AGRESIVA - SIEMPRE funciona\"\"\"\n",
    "    try:\n",
    "        texto_completo = bloque.text.strip()\n",
    "        if len(texto_completo) < 15:\n",
    "            return None\n",
    "            \n",
    "        # 💰 PRECIO - MÁS FLEXIBLE\n",
    "        patron_precio = r'\\$[\\d,\\.\\s]+(?:\\$[\\d,\\.\\s]+\\$)?'\n",
    "        precio_match = re.search(patron_precio, texto_completo)\n",
    "        if not precio_match:\n",
    "            return None\n",
    "        precio = precio_match.group()\n",
    "        \n",
    "        # 📝 NOMBRE - CUALQUIER TEXTO CON >3 CARACTERES\n",
    "        lineas = texto_completo.split('\\n')\n",
    "        candidatos = []\n",
    "        for linea in lineas:\n",
    "            linea_limpia = linea.strip()\n",
    "            if len(linea_limpia) > 3 and '$' not in linea_limpia and not linea_limpia.isdigit():\n",
    "                candidatos.append(linea_limpia)\n",
    "        \n",
    "        if not candidatos:\n",
    "            return None\n",
    "            \n",
    "        nombre_completo = max(candidatos, key=len)\n",
    "        \n",
    "        # 🏷️ MARCA\n",
    "        marca = extraer_marca(nombre_completo)\n",
    "        nombre_limpio = limpiar_nombre(nombre_completo, marca)\n",
    "        \n",
    "        # ID único\n",
    "        identificador = f\"{nombre_limpio[:60].lower()}_{marca.lower()}\"\n",
    "        if identificador in productos_vistos:\n",
    "            return None\n",
    "        productos_vistos.add(identificador)\n",
    "        \n",
    "        return {\n",
    "            \"nombre\": nombre_limpio[:100],\n",
    "            \"nombre_completo\": nombre_completo[:120],\n",
    "            \"precio\": precio,\n",
    "            \"marca\": marca,\n",
    "            \"categoria\": detectar_categoria(nombre_limpio.lower()),\n",
    "            \"pagina\": pagina_actual\n",
    "        }\n",
    "    except:\n",
    "        return None\n",
    "\n",
    "def extraer_marca(nombre):\n",
    "    marcas = ['LUCCHETTI','TUCAPEL','IANSA','CAROZZI','MIRAFLORES','HELLMANNS','LIDER','ACUENTA','SELECTA','LA ROMA','NETO','KRAFT','MAGGI']\n",
    "    for marca in marcas:\n",
    "        if marca.upper() in nombre.upper():\n",
    "            return marca\n",
    "    return \"GENÉRICA\"\n",
    "\n",
    "def limpiar_nombre(nombre, marca):\n",
    "    return re.sub(rf'\\b{re.escape(marca)}\\b\\s*$', '', nombre, flags=re.IGNORECASE).strip()\n",
    "\n",
    "def detectar_categoria(nombre):\n",
    "    nombre_lower = nombre.lower()\n",
    "    for palabra, cat in CATEGORIAS.items():\n",
    "        if palabra in nombre_lower:\n",
    "            return cat\n",
    "    return \"Despensa\"\n",
    "\n",
    "# 🚀 SCRAPING PRINCIPAL CON RECONEXIÓN\n",
    "driver = None\n",
    "for pagina_actual in range(1, MAX_PAGINAS + 1):\n",
    "    try:\n",
    "        if driver is None or driver.session_id is None:\n",
    "            print(f\"\\n🔄 RECONEXIÓN PÁGINA {pagina_actual}\")\n",
    "            if driver:\n",
    "                driver.quit()\n",
    "            driver = crear_driver()\n",
    "            time.sleep(3)\n",
    "        \n",
    "        url_pagina = URL_BASE if pagina_actual == 1 else f\"{URL_BASE}?currentPage={pagina_actual}\"\n",
    "        print(f\"\\n📄 PÁGINA {pagina_actual:2d}/15 ({pagina_actual/MAX_PAGINAS*100:>5.1f}%)\")\n",
    "        \n",
    "        driver.get(url_pagina)\n",
    "        time.sleep(8)\n",
    "\n",
    "        # Cookies\n",
    "        try:\n",
    "            WebDriverWait(driver, 5).until(EC.element_to_be_clickable((By.XPATH, \"//button[contains(text(), 'Aceptar') or contains(text(), 'Acepto')]\"))).click()\n",
    "        except:\n",
    "            pass\n",
    "\n",
    "        # SCROLL AGRESIVO\n",
    "        for _ in range(25):\n",
    "            driver.execute_script(\"window.scrollTo(0, document.body.scrollHeight);\")\n",
    "            time.sleep(1.2)\n",
    "        time.sleep(5)\n",
    "\n",
    "        # 🔍 TODOS LOS SELECTORES POSIBLES\n",
    "        selectores = [\n",
    "            \"div[class*='product']\",\n",
    "            \"div[class*='ProductCard']\",\n",
    "            \"div[class*='product-card']\",\n",
    "            \"article\",\n",
    "            \".product-item\"\n",
    "        ]\n",
    "        \n",
    "        todos_bloques = []\n",
    "        for selector in selectores:\n",
    "            try:\n",
    "                bloques = driver.find_elements(By.CSS_SELECTOR, selector)\n",
    "                todos_bloques.extend(bloques)\n",
    "                print(f\"   🔍 {selector}: {len(bloques)}\")\n",
    "            except:\n",
    "                pass\n",
    "        \n",
    "        todos_bloques = list(set(todos_bloques))  # Eliminar duplicados\n",
    "        \n",
    "        print(f\"   ✅ {len(todos_bloques)} bloques únicos\")\n",
    "\n",
    "        # EXTRAER\n",
    "        productos_esta_pagina = 0\n",
    "        for bloque in todos_bloques:\n",
    "            producto = extraer_producto(bloque)\n",
    "            if producto:\n",
    "                producto[\"supermercado\"] = \"ACUENTA\"\n",
    "                producto[\"fecha_scraping\"] = time.strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "                producto[\"url\"] = url_pagina\n",
    "                producto[\"posicion\"] = len(datos_finales) + 1\n",
    "                datos_finales.append(producto)\n",
    "                productos_esta_pagina += 1\n",
    "        \n",
    "        print(f\"   🎉 +{productos_esta_pagina:3d} productos | TOTAL: {len(datos_finales):4d}\")\n",
    "\n",
    "    except WebDriverException as e:\n",
    "        print(f\"   ❌ WebDriver error: {e}\")\n",
    "        driver = None  # Forzar reconexión\n",
    "        time.sleep(5)\n",
    "        continue\n",
    "    except Exception as e:\n",
    "        print(f\"   ⚠️ Error página {pagina_actual}: {e}\")\n",
    "        time.sleep(3)\n",
    "        continue\n",
    "\n",
    "print(f\"\\n🎉 ¡SCRAPE FINALIZADO! {len(datos_finales)} productos de 15 páginas\")\n",
    "\n",
    "# 💰 LIMPIEZA\n",
    "precios_limpios = []\n",
    "for d in datos_finales:\n",
    "    match = re.search(r'\\$([0-9]{1,3}(?:\\.[0-9]{3})*)', d[\"precio\"])\n",
    "    if match:\n",
    "        try:\n",
    "            d[\"precio_limpio\"] = float(match.group(1).replace('.', ''))\n",
    "            precios_limpios.append(d[\"precio_limpio\"])\n",
    "        except:\n",
    "            pass\n",
    "\n",
    "# 📊 TABLA\n",
    "print(\"\\n\" + \"=\"*140)\n",
    "print(f\"{'PRODUCTOS TOTALES':<45} {len(datos_finales):>5} | {'COSTO TOTAL':<15} ${sum(precios_limpios):>10,.0f}\")\n",
    "print(\"=\"*140)\n",
    "\n",
    "# TOP 20 + ÚLTIMOS 10\n",
    "for i, d in enumerate(datos_finales[:20], 1):\n",
    "    precio = d.get(\"precio_limpio\", 0)\n",
    "    print(f\"{i:>3}. {d['nombre'][:45]:<45} {d['marca']:<12} ${precio:>8,.0f} ({d['pagina']})\")\n",
    "\n",
    "print(\"...\" + \".\"*60)\n",
    "for i, d in enumerate(datos_finales[-10:], len(datos_finales)-9):\n",
    "    precio = d.get(\"precio_limpio\", 0)\n",
    "    print(f\"{i:>3}. {d['nombre'][:45]:<45} {d['marca']:<12} ${precio:>8,.0f} ({d['pagina']})\")\n",
    "\n",
    "# 💾\n",
    "with open(\"canasta_15p_estable.json\", \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump(datos_finales, f, ensure_ascii=False, indent=2)\n",
    "print(\"\\n💾 ✅ canasta_15p_estable.json\")\n",
    "\n",
    "print(\"\\n🎉 ¡15 PÁGINAS ESTABLES! ✅\")"
   ]
